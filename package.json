{
  "name": "docsystem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Consultancy document system — see README.md and docs/",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "test": "vitest run",
    "test:perf": "vitest run tests/perf/benchmark.test.ts",
    "test:watch": "vitest",
    "validate": "node scripts/validate.mjs",
    "export:pdf": "node scripts/export-pdf.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "setup:scan-demos": "tsx src/setup/scan-demos.ts",
    "setup:install": "node scripts/setup-install.mjs",
    "setup:validate": "tsx src/setup/validate.ts",
    "setup:regenerate": "tsx src/setup/regenerate.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "2.0.3",
    "@tauri-apps/plugin-dialog": "2.0.1",
    "@tauri-apps/plugin-fs": "2.0.3",
    "@tauri-apps/plugin-store": "2.1.0",
    "@tiptap/core": "2.8.0",
    "@tiptap/extension-link": "2.8.0",
    "@tiptap/extension-table": "2.8.0",
    "@tiptap/extension-table-cell": "2.8.0",
    "@tiptap/extension-table-header": "2.8.0",
    "@tiptap/extension-table-row": "2.8.0",
    "@tiptap/extension-underline": "2.8.0",
    "@tiptap/pm": "2.8.0",
    "@tiptap/react": "2.8.0",
    "@tiptap/starter-kit": "2.8.0",
    "better-sqlite3": "12.10.0",
    "date-fns": "3.6.0",
    "echarts": "5.5.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "mermaid": "10.9.1",
    "officeparser": "^5.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "yaml": "2.5.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.0.4",
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "16.0.1",
    "@types/better-sqlite3": "7.6.11",
    "@types/node": "20.16.5",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "8.5.0",
    "@typescript-eslint/parser": "8.5.0",
    "@vitejs/plugin-react": "4.3.1",
    "docx": "^8.5.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-react": "7.36.1",
    "eslint-plugin-react-hooks": "5.1.0-rc-fb9a90fa48-20240614",
    "happy-dom": "15.7.4",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.6.82",
    "playwright": "1.47.0",
    "pptxgenjs": "^3.12.0",
    "prettier": "3.3.3",
    "tsx": "4.19.1",
    "typescript": "5.6.2",
    "vite": "5.4.6",
    "vitest": "2.1.1"
  },
  "engines": {
    "node": ">=20.11.0",
