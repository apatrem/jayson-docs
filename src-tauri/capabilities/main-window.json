{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Permissions for the main application window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "store:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "path": "$TEMP/docsystem-export/**" }]
    }
  ]
}
