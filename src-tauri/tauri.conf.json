{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Document System",
  "version": "0.1.0",
  "identifier": "com.consultancy.docsystem",

  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Document System",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],

    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: https://api.anthropic.com https://api.openai.com; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Dropbox/**",
          "$HOME/Library/Mobile Documents/**",
          "$HOME/Google Drive/**",
          "$HOME/OneDrive/**",
          "$HOME/Documents/**",
          "$HOME/Consultancy-Shared/**",
          "$APPCONFIG/**"
        ]
      },
      "capabilities": ["main-window"]
    }
  },

  "plugins": {
    "shell": {
      "open": "(?:https?://[^\\s<>\"]+|(?:/|[A-Z]:\\\\)[^\\n]*[/\\\\]docsystem-export[/\\\\][0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}[/\\\\][^/\\\\]+\\.html)"
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Consultancy document system",
    "longDescription": "Schema-anchored document and deck editor with comment-to-AI workflow.",

    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },

    "windows": {
      "wix": null,
      "nsis": null,
      "webviewInstallMode": { "type": "embedBootstrapper" }
    },

    "linux": {
      "appimage": { "bundleMediaFramework": false },
      "deb": { "depends": [] }
    }
  }
}
